{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node"],
    "paths": {
      "@sisu-ai/vector-core": ["./packages/vector/core/src/index.ts"],
      "@sisu-ai/rag-core": ["./packages/rag/core/src/index.ts"]
    },
    "lib": [
      "ES2021"
    ],
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist"
  }
}
